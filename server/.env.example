# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# URL frontend yang diizinkan (CORS). Pisahkan dengan koma untuk banyak origin.
CLIENT_URL=http://localhost:3000

# ─── Database (Postgres) ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pensil
DB_USER=postgres
DB_PASSWORD=postgres
# Opsional: kalau diisi, ini dipakai dan field DB_* di atas diabaikan.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/pensil

# ─── Auth (JWT) ──────────────────────────────────────────
JWT_SECRET=ganti-dengan-string-acak-yang-panjang
JWT_EXPIRES_IN=7d
